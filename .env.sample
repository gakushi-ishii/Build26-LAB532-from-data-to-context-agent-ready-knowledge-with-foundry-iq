# Azure AI Search Configuration
# LAB532 uses the magottei-eastus2euap preview search service.
AZURE_TENANT_ID=72f988bf-86f1-41af-91ab-2d7cd011db47
AZURE_SEARCH_SERVICE_ENDPOINT=https://magottei-eastus2euap.search.windows.net
AZURE_SEARCH_ADMIN_KEY=your-search-admin-key

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.services.ai.azure.com/
AZURE_OPENAI_KEY=your-openai-api-key
AZURE_OPENAI_CHATGPT_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_CHATGPT_MODEL_NAME=gpt-5.4-mini

# MAI Grounding MCP
MAI_GROUNDING_ENDPOINT=https://api.microsoft.ai/v3/mcp
MAI_GROUNDING_KEY=your-mai-grounding-key
MAI_GROUNDING_KEY_HEADER=x-apikey
MAI_GROUNDING_TOOL=web

# Fabric IQ Ontology
FABRIC_ENDPOINT=https://api.fabric.microsoft.com
FABRIC_TENANT_ID=72f988bf-86f1-41af-91ab-2d7cd011db47
FABRIC_WORKSPACE_ID=f200c1bc-e2ec-43b9-9308-be868f68753e
FABRIC_ONTOLOGY_ID=dc900177-5ed8-4bb0-b4c4-85ef346c23c0

# Fabric Lakehouse data setup output
FABRIC_DATA_WORKSPACE_ID=f200c1bc-e2ec-43b9-9308-be868f68753e
FABRIC_LAKEHOUSE_ID=d89a7d80-5b0d-446a-95f7-caf8c36fb14a
FABRIC_LAKEHOUSE_NAME=ZavaDIYLakehouse

# Fabric Lakehouse setup script inputs
LAKEHOUSE_NAME=ZavaDIYLakehouse
FABRIC_ONTOLOGY_NAME=ZavaDIYOntology
CREATE_ONTOLOGY=true

# Optional project configuration
PROJECT_ENDPOINT=https://your-ai-services.services.ai.azure.com/api/projects/your-project
PROJECT_RESOURCE_ID=
PROJECT_CONNECTION_NAME=kb-mcp-connection
