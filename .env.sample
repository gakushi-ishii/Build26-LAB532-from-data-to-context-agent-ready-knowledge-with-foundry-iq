# Azure AI Search Configuration
AZURE_SEARCH_SERVICE_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_ADMIN_KEY=your-search-admin-key

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.services.ai.azure.com/
AZURE_OPENAI_KEY=your-openai-api-key
AZURE_OPENAI_CHATGPT_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_CHATGPT_MODEL_NAME=gpt-5.4
AZURE_TENANT_ID=your-tenant-id

# Fabric IQ (Parts 3, 5)
FABRIC_WORKSPACE_ID=your-fabric-workspace-id
FABRIC_ONTOLOGY_ID=your-fabric-ontology-id

# Microsoft Speedbird Search (live web search)
MS_SPEEDBIRD_SEARCH_KEY=your-microsoft-speedbird-search-key
